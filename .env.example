ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Temporary access gate (proxy.ts HTTP Basic Auth). Set BOTH to turn the gate
# on; leave either unset and the app is fully open. This is a stopgap while
# Firebase auth below is disabled.
GATE_USER=pick_a_username
GATE_PASS=pick_a_strong_password

# --- Firebase auth is currently DISABLED (kept in code, not wired up) ---
# The keys below are only needed when re-enabling Google / email-password auth.

# Firebase client SDK — from the Web app's firebaseConfig
# (Firebase Console → Project settings → General → Your apps → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Admin SDK — from the service-account JSON
# (Firebase Console → Project settings → Service accounts → Generate new private key)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
# Wrap in quotes and keep the literal \n escapes; firebase-admin.ts un-escapes them
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
